{
  "manifest_version": 3,
  "name": "AccessibleName Inspector",
  "version": "1.1.0",
  "description": "Multi-check accessibility inspector: accessible names, headings, and more. Reports across iframes (including cross-origin) and shadow DOM. No network calls.",
  "permissions": [
    "activeTab",
    "scripting",
    "tabs"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "action": {
    "default_title": "AccessibleName Inspector",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "commands": {
    "run-names": {
      "suggested_key": {
        "default": "Alt+A"
      },
      "description": "Scan accessible names"
    },
    "run-headings": {
      "suggested_key": {
        "default": "Alt+H"
      },
      "description": "Inspect heading structure"
    },
    "run-landmarks": {
      "suggested_key": {
        "default": "Alt+L"
      },
      "description": "Inspect landmarks / page regions"
    }
  }
}
