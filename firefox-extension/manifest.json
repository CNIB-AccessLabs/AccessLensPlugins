{
  "manifest_version": 3,
  "name": "AccessibleName Inspector",
  "version": "1.1.0",
  "description": "Multi-check accessibility inspector: accessible names, headings, and more. Reports across iframes (including cross-origin) and shadow DOM. No network calls.",
  "permissions": ["activeTab", "scripting", "tabs"],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_title": "AccessibleName Inspector",
    "default_popup": "popup.html",
    "default_icon": {
      "48": "icons/icon-48.svg",
      "128": "icons/icon-128.svg"
    }
  },
  "icons": {
    "48": "icons/icon-48.svg",
    "128": "icons/icon-128.svg"
  },
  "background": {
    "scripts": ["background.js"]
  },
  "commands": {
    "run-names": {
      "suggested_key": { "default": "Alt+A" },
      "description": "Scan accessible names"
    },
    "run-headings": {
      "suggested_key": { "default": "Alt+H" },
      "description": "Inspect heading structure"
    },
    "run-landmarks": {
      "suggested_key": { "default": "Alt+L" },
      "description": "Inspect landmarks / page regions"
    }
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "a11y-names@cnib.ca",
      "strict_min_version": "115.0"
    }
  }
}
